#!/usr/bin/env bash
# booch CLI。現状はサブコマンド init（利用側 dotfiles 雛形の生成）のみ。
# ライブラリ／ランナーとしての使い方は README を参照（CLI は補助で、本体は source して使う）。
set -uo pipefail

BOOCH_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
export BOOCH_ROOT

_booch_usage() {
  cat <<'USAGE'
booch - WSL2 / Ubuntu 向け開発環境ブートストラップ基盤

使い方:
  booch init <dir>     利用側 dotfiles リポジトリの雛形を <dir> に生成する（冪等）
  booch version        バージョンを表示する
  booch help           このヘルプ + モジュール一覧を表示する
  booch help <name>    モジュール（例: fs / doctor / go）の API を表示する

ランナー／ライブラリとしての使い方は README.md を参照。
USAGE
}

cmd=${1:-}
case "$cmd" in
  init)
    shift
    source "$BOOCH_ROOT/lib/scaffold.sh"
    booch_scaffold "${1:-}"
    ;;
  version | -V | --version)
    source "$BOOCH_ROOT/lib/runner.sh"
    booch_version
    ;;
  help | -h | --help)
    shift
    source "$BOOCH_ROOT/lib/apidoc.sh"
    if [ -n "${1:-}" ]; then
      booch_apidoc_show "$1"        # booch help <name>: モジュール詳細
    else
      _booch_usage
      printf '\n'
      booch_apidoc_index            # booch help: ヘルプ + モジュール一覧
    fi
    ;;
  "")
    _booch_usage >&2
    exit 1
    ;;
  *)
    echo "booch: 不明なサブコマンド: $cmd" >&2
    echo "  booch help でヘルプを表示" >&2
    exit 1
    ;;
esac
